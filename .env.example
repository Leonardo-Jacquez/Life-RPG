# Database
DATABASE_URL=postgres://user:password@localhost:5432/life_rpg
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Google OAuth (for Google Classroom SSO)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Clever SSO
CLEVER_CLIENT_ID=
CLEVER_CLIENT_SECRET=
CLEVER_REDIRECT_URI=http://localhost:3001/auth/clever/callback

# External data APIs
BLS_API_KEY=
CENSUS_API_KEY=

# App
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# Research data export (separate secret for export endpoints)
RESEARCH_EXPORT_SECRET=change_me_in_production
